# --------------------------------------------------------------------------
# .env.local.example
#
# Copy this file to `.env.local` for local dev. NEVER commit `.env.local`.
# On Vercel, add each of these in Project → Settings → Environment Variables,
# scoped to Production + Preview (and Development if you want `vercel env pull`
# to work).
#
# Test vs live:
#   - In test mode, all keys start with `rzp_test_` and use the test webhook
#     secret. No real money moves.
#   - In live mode, keys start with `rzp_live_`. Only available after your
#     Razorpay account passes KYC.
# --------------------------------------------------------------------------

# Razorpay API credentials (Razorpay Dashboard → Settings → API Keys)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Mirror of RAZORPAY_KEY_ID exposed to the browser. (Optional — the server
# returns the key to the client in /api/razorpay/create-subscription, so the
# page never needs to read this directly. Set it only if you want to hard-code
# the key into client bundles for some reason.)
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXX

# Webhook secret you set when creating the webhook at
# Razorpay Dashboard → Webhooks → Add New Webhook.
# Used to verify the x-razorpay-signature header in /api/razorpay/webhook.
RAZORPAY_WEBHOOK_SECRET=a-long-random-string-you-paste-into-razorpay-too

# Razorpay plan IDs (Razorpay Dashboard → Subscriptions → Plans → Create Plan)
# Each plan you create returns a plan_id like `plan_ABC123XYZ`. Paste them here.
# These map to the `slug`s in data/site-config.ts → PRICING_PLANS.
RAZORPAY_PLAN_ID_PRO_MONTHLY=plan_XXXXXXXXXXXX
RAZORPAY_PLAN_ID_PRO_ANNUAL=plan_XXXXXXXXXXXX
